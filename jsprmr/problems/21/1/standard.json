        }
      }
    },
    {
      "name": "数量が負の数",
      "input": {
        "type": "value",
        "value": {
          "price": 120,
          "quantity": -1
        }
      },
      "output": {
        "type": "value",
        "value": {
          "ok": false,
          "name": "Error",
          "message": "quantity must be at least 1"
        }
      }
    },
    {
      "name": "数量が文字列",
      "input": {
        "type": "value",
        "value": {
          "price": 500,
          "quantity": "2"
