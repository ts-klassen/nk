{
  "name": "node-backend-training",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "db:up": "docker-compose up -d mysql",
    "db:down": "docker-compose down -v",
    "db:reset:a": "node scripts/reset-db.mjs system-a/sql/schema.sql backend_training_a",
    "db:reset:b": "node scripts/reset-db.mjs system-b/sql/schema.sql backend_training_b",
    "build:a": "tsc -p system-a/tsconfig.json",
    "start:practice": "npm run build:a && node system-a/dist/practice-server.js",
    "start:a": "node system-a/dist/server.js",
    "dev:a": "npm run build:a && npm run start:a",
    "build:b": "tsc -p system-b/tsconfig.json",
    "start:b": "node system-b/dist/server.js",
    "test:b": "npm run build:b && mocha \"system-b/test/**/*.test.mjs\" --timeout 10000"
  },
  "engines": {
    "node": ">=22"
  },
  "dependencies": {
    "argon2": "^0.43.0",
    "express": "^5.1.0",
    "express-validator": "^7.2.1",
    "mysql2": "^3.14.0"
  },
  "devDependencies": {
    "@types/express": "^5.0.0",
    "@types/mocha": "^10.0.10",
    "@types/node": "^22.13.0",
    "chai": "^5.2.0",
    "mocha": "^11.1.0",
    "typescript": "^5.8.2"
  }
}
